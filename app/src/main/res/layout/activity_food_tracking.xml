<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/theme_gray_bg"
    tools:context=".FoodTrackingActivity">

    <View
        android:id="@+id/trackingHeader"
        android:layout_width="match_parent"
        android:layout_height="60dp"
        android:background="@color/white"
        app:layout_constraintTop_toTopOf="parent" />

    <ImageView
        android:id="@+id/btnBack"
        android:layout_width="48dp"
        android:layout_height="48dp"
        android:padding="12dp"
        android:src="@android:drawable/ic_menu_revert"
        app:layout_constraintBottom_toBottomOf="@id/trackingHeader"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="@id/trackingHeader"
        app:tint="@color/black" />

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="TRACK ORDER"
        android:textColor="@color/black"
        android:textSize="18sp"
        android:textStyle="bold"
        app:layout_constraintBottom_toBottomOf="@id/trackingHeader"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="@id/trackingHeader" />

    <androidx.cardview.widget.CardView
        android:id="@+id/cardStatus"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_margin="24dp"
        app:cardCornerRadius="24dp"
        app:cardElevation="8dp"
        app:layout_constraintTop_toBottomOf="@id/trackingHeader">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="24dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Order Status"
                android:textColor="@color/black"
                android:textSize="22sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/tvTrackingStatusDate"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:text="31 May 2026 10:09 PM"
                android:textColor="@color/theme_text_hint" />

            <!-- Status 1 -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="24dp"
                android:orientation="horizontal">
                <View android:layout_width="20dp" android:layout_height="20dp" android:background="@android:drawable/presence_online" />
                <LinearLayout android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginStart="16dp" android:orientation="vertical">
                    <TextView android:id="@+id/tvStatus1" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Order Placed" android:textColor="@color/black" android:textStyle="bold" />
                    <TextView android:id="@+id/tvStatusDesc1" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="We have received your order" android:textColor="@color/theme_text_hint" android:textSize="12sp" />
                </LinearLayout>
            </LinearLayout>

            <!-- Status 2 -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:orientation="horizontal">
                <View android:layout_width="20dp" android:layout_height="20dp" android:background="@android:drawable/presence_away" />
                <LinearLayout android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginStart="16dp" android:orientation="vertical">
                    <TextView android:id="@+id/tvStatus2" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Packing Product" android:textColor="@color/black" android:textStyle="bold" />
                    <TextView android:id="@+id/tvStatusDesc2" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Dealer is packing your order" android:textColor="@color/theme_text_hint" android:textSize="12sp" />
                </LinearLayout>
            </LinearLayout>

            <!-- Status 3 -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:orientation="horizontal">
                <View android:layout_width="20dp" android:layout_height="20dp" android:background="@android:drawable/presence_away" />
                <LinearLayout android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginStart="16dp" android:orientation="vertical">
                    <TextView android:id="@+id/tvStatus3" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Out for Delivery" android:textColor="@color/black" android:textStyle="bold" />
                    <TextView android:id="@+id/tvStatusDesc3" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Delivery partner is on the way" android:textColor="@color/theme_text_hint" android:textSize="12sp" />
                </LinearLayout>
            </LinearLayout>

        </LinearLayout>
    </androidx.cardview.widget.CardView>

    <Button
        android:id="@+id/btnChatWithDriver"
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:layout_marginHorizontal="24dp"
        android:layout_marginTop="24dp"
        android:backgroundTint="@color/theme_accent_green"
        android:text="CHAT WITH DRIVER"
        android:textAllCaps="false"
        android:textStyle="bold"
        app:cornerRadius="24dp"
        app:layout_constraintTop_toBottomOf="@id/cardStatus" />

    <Button
        android:id="@+id/btnReceived"
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:layout_marginHorizontal="24dp"
        android:layout_marginTop="16dp"
        android:backgroundTint="@color/theme_accent_green"
        android:text="MARK AS RECEIVED"
        android:textAllCaps="false"
        android:textStyle="bold"
        app:cornerRadius="24dp"
        app:layout_constraintTop_toBottomOf="@id/btnChatWithDriver" />

    <LinearLayout
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="24dp"
        android:orientation="horizontal"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/btnReceived">

        <androidx.cardview.widget.CardView
            android:id="@+id/btnCall"
            android:layout_width="60dp"
            android:layout_height="60dp"
            android:layout_marginEnd="16dp"
            app:cardBackgroundColor="@color/theme_accent_green"
            app:cardCornerRadius="16dp">

            <ImageView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center"
                android:src="@android:drawable/ic_menu_call"
                app:tint="@color/white" />
        </androidx.cardview.widget.CardView>

        <androidx.cardview.widget.CardView
            android:id="@+id/btnChat"
            android:layout_width="60dp"
            android:layout_height="60dp"
            android:layout_marginStart="16dp"
            app:cardBackgroundColor="@color/theme_accent_orange"
            app:cardCornerRadius="16dp">

            <ImageView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center"
                android:src="@android:drawable/ic_menu_send"
                app:tint="@color/white" />
        </androidx.cardview.widget.CardView>
    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>